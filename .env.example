# ============================================
# AI Provider Configuration
# ============================================
# Supported values: 'openai' or 'sarvam'
AI_PROVIDER=openai

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=add_key_here
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_5=gpt-5

# ============================================
# SarvamAI Configuration
# Only required if AI_PROVIDER=sarvam
# ============================================
SARVAM_API_KEY=your-sarvam-api-subscription-key-here
SARVAM_MODEL_DEFAULT=sarvam-2b-v0.5
SARVAM_MODEL_5=sarvam-2b-v0.5

# ============================================
# YouTube API Configuration
# ============================================
YOUTUBE_API_KEY=add_key_here
